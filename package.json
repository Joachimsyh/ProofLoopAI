{
  "name": "proofloop",
  "version": "1.0.0",
  "private": true,
  "description": "Turn hidden customer proof into your growth engine.",
  "scripts": {
    "predev": "node scripts/dev-health-check.mjs",
    "dev": "npm run dev --prefix apps/web",
    "install:all": "npm install && npm install --prefix apps/web",
    "vercel-build": "npm run build --prefix apps/web",
    "build": "npm run build --prefix apps/web",
    "start": "npm run start --prefix apps/web",
    "db:generate": "npm run db:generate --prefix apps/web",
    "db:migrate": "npm run db:migrate --prefix apps/web",
    "db:setup": "npm run db:setup --prefix apps/web",
    "db:seed": "npm run db:seed --prefix apps/web",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": "20.x"
  }
}
